rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: categories
    // Document ID: categoryId
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - slug: string (required)
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - categoryId: string (required)
    //   - type: string (required, enum: ['digital', 'service'])
    //   - image: string (optional)
    //   - slug: string (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - userId: string (required)
    //   - productId: string (required)
    //   - amount: number (required)
    //   - status: string (required, enum: ['pending', 'completed', 'cancelled'])
    //   - paymentMethod: string (optional)
    //   - paymentDetails: map (optional)
    //
    // Collection: visitors
    // Document ID: visitorId
    // Fields:
    //   - path: string (required)
    //   - timestamp: timestamp (required)
    //   - userAgent: string (optional)
    //   - ip: string (optional)
    //   - location: map (optional)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum: ['admin', 'user'])
    //   - displayName: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "botassist.org@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
    }

    match /visitors/{visitorId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && 
        (request.resource.data.role == 'user' || 
         (request.auth.token.email == "botassist.org@gmail.com" && request.auth.token.email_verified == true && request.resource.data.role == 'admin'));
      allow update: if isAdmin();
    }
  }
}
