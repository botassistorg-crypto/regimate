{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product or service category",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "description": { "type": "string", "description": "Category description" },
        "slug": { "type": "string", "description": "URL-friendly slug" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "Digital product or service",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Detailed description in Markdown" },
        "shortDescription": { "type": "string", "description": "Short summary" },
        "price": { "type": "number", "description": "Price in BDT" },
        "categoryId": { "type": "string", "description": "ID of the category" },
        "type": { "type": "string", "enum": ["digital", "service"], "description": "Type of item" },
        "image": { "type": "string", "description": "Image URL" },
        "slug": { "type": "string", "description": "URL-friendly slug" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "categoryId", "type", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User UID" },
        "productId": { "type": "string", "description": "Product ID" },
        "amount": { "type": "number", "description": "Total amount" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"], "description": "Order status" },
        "paymentMethod": { "type": "string", "description": "Payment method (e.g. bKash)" },
        "paymentDetails": { "type": "object", "description": "Payment details (e.g. transaction ID)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "amount", "status"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "Visitor tracking data",
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "Page path visited" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string", "description": "Browser user agent" },
        "ip": { "type": "string", "description": "Anonymized IP" },
        "location": { "type": "object", "description": "Approximate location" }
      },
      "required": ["path", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "displayName": { "type": "string", "description": "User display name" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": { "schema": "Category", "description": "Categories collection" },
    "/products/{productId}": { "schema": "Product", "description": "Products and services collection" },
    "/orders/{orderId}": { "schema": "Order", "description": "Orders collection" },
    "/visitors/{visitorId}": { "schema": "Visitor", "description": "Visitor logs" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" }
  }
}
